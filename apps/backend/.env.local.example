# Claude — simulation engine
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Insforge — backend-as-a-service
INSFORGE_BASE_URL=
INSFORGE_ANON_KEY=

# Upstash Redis — Phase 2 parallel simulation transport
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# TinyFish — Phase 4 live web grounding (optional; sims still run without it)
TINYFISH_API_KEY=

# CORS — comma-separated list of frontend origins allowed to hit /api/*
ALLOWED_ORIGINS=http://localhost:3000
